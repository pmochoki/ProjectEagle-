# Supabase (Postgres + Auth)
SUPABASE_URL=https://twojjtkqifmscxvrettm.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=your-anon-key
# Frontend (Vercel + local Next.js) — same URL/key, publishable/anon only
NEXT_PUBLIC_SUPABASE_URL=https://twojjtkqifmscxvrettm.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Local automation: your Supabase user UUID after first sign-up (scrapers attach jobs to this account)
AUTOMATION_USER_ID=

# LinkedIn (secondary account) — recommended logged-in mode
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=
JOB_SEARCH_TITLE=Mechatronics Engineer
JOB_SEARCH_LOCATION=European Union
JOB_SEARCH_EXPERIENCE_LEVEL=entry
JOB_SEARCH_DATE_POSTED=past_month
SCRAPER_MAX_PAGES=3
SCRAPER_DELAY_MIN=3
SCRAPER_DELAY_MAX=15
SCRAPER_HEADLESS=true
# Guest/public LinkedIn search without login (fewer results; more CAPTCHA)
SCRAPER_PUBLIC_MODE=false
# EU multi-country scan — leave empty or set to "all" for every European country (default).
# Or comma-list a subset, e.g. Germany,Netherlands,Sweden
EU_JOB_LOCATIONS=all
EXCLUDE_LOCATIONS=
HU_JOB_LOCATIONS=Hungary,Budapest
# Hungary-first: always include HU in every EU batch + dedicated HU scans
HUNGARY_FOCUS=true
HUNGARY_SCRAPE_INTERVAL_HOURS=4
# Comma-separated LinkedIn job titles (EU + Hungary scans rotate through these)
JOB_SEARCH_TITLES=Mechatronics Engineer,Robotics Engineer,Automation Engineer,Graduate Mechanical Engineer,Control Systems Engineer
# Skip irrelevant listings (title or description must match one keyword)
JOB_RELEVANCE_KEYWORDS=mechatronics,robotics,automation,control,mechanical,embedded,firmware,manufacturing,engineer,graduate,scholarship,master,msc
SCHOLARSHIP_SEARCH_KEYWORDS=mechatronics masters scholarship Europe,MSc robotics scholarship,engineering master funding Europe,Erasmus Mundus mechatronics,DAAD scholarship engineering,Stipendium Hungaricum engineering,graduate scholarship mechanical engineering EU,master scholarship Hungary engineering,fully funded master robotics Europe
SCHOLARSHIP_SEARCH_LOCATIONS=all

# Around-the-clock automation (local backend only — not on Vercel serverless)
AUTOMATION_ENABLED=true
AUTOMATION_POLL_MINUTES=30
SCRAPE_EU_INTERVAL_HOURS=6
SCRAPE_SCHOLARSHIP_INTERVAL_HOURS=8
SCRAPE_PROFESSION_INTERVAL_HOURS=6
SCRAPE_LOCATIONS_PER_CYCLE=2
APPLY_ENABLED=true
APPLY_MAX_PER_DAY=6
APPLY_MIN_INTERVAL_MINUTES=45

# Application safety — defaults ON (blocks auto-submit until /approve)
REVIEW_BEFORE_SUBMIT=true

# Profile matching — applicant needs EU work visa sponsorship (penalizes "no sponsorship" listings)
APPLICANT_NEEDS_VISA_SPONSORSHIP=true

# Claude (cover letters + application help)
CLAUDE_API_KEY=
# Optional override (default: claude-sonnet-4-20250514)
CLAUDE_MODEL=

# Telegram bot (outbound alerts + inbound /answer /approve commands)
TELEGRAM_BOT_TOKEN=
# Your personal chat ID (DM alerts + commands)
TELEGRAM_CHAT_ID=
# Optional Telegram channel ID (e.g. -1001234567890) for channel commands + alerts
# Add the bot as a channel admin with "Post messages" permission.
TELEGRAM_CHANNEL_ID=
# Optional comma-separated override for all notify/command destinations
# TELEGRAM_NOTIFY_CHAT_IDS=123456789,-1001234567890
# Daily summary at 10pm local time (backend must be running)
DAILY_SUMMARY_TIMEZONE=Europe/Budapest
DAILY_SUMMARY_HOUR_LOCAL=22
# Legacy UTC-only mode (used when DAILY_SUMMARY_TIMEZONE is unset)
DAILY_SUMMARY_HOUR_UTC=7

# Frontend → backend (optional; production Vercel defaults to /api)
NEXT_PUBLIC_API_URL=http://localhost:8000
# --- URGENCY (3-month permit countdown) ---
PERMIT_DEADLINE=2026-10-29
URGENCY_MODE=true
# Urgency overrides (when active): 15min checks, 2h LinkedIn, 1h Hungary, 3h profession.hu, 10 applies/day

# Public dashboard URL for Telegram approval links
FRONTEND_URL=https://project-eagle-six.vercel.app
SCRAPE_EXTRA_INTERVAL_HOURS=4

# LinkedIn auth backoff + search caps
LINKEDIN_AUTH_BACKOFF_BASE_SECONDS=60
LINKEDIN_AUTH_BACKOFF_MAX_SECONDS=3600
LINKEDIN_MAX_SEARCHES_PER_CYCLE=6
LINKEDIN_DAILY_SEARCH_CAP=40
# Run logged-in DOM canary before each LinkedIn automation batch
CANARY_BEFORE_SCRAPE=false
CANARY_USE_SESSION=true
# Urgency overrides: URGENCY_LINKEDIN_MAX_SEARCHES_PER_CYCLE=12, URGENCY_LINKEDIN_DAILY_SEARCH_CAP=80

# Extra job sources (no API key required unless noted)
# EURES — EU public job portal (enabled by default in EU scans)
EURES_ENABLED=true
# Indeed EU guest search (Playwright; no API key)
INDEED_ENABLED=true
INDEED_MAX_PAGES=2
# Arbeitnow + RemoteOK JSON APIs
ARBEITNOW_ENABLED=true
REMOTEOK_ENABLED=true
# Adzuna — optional; sign up at https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
ADZUNA_COUNTRY=at
ADZUNA_ENABLED=false
