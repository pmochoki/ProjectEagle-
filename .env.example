# Supabase (Postgres)
SUPABASE_URL=https://twojjtkqifmscxvrettm.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=your-anon-key

# LinkedIn (secondary account) — optional if SCRAPER_PUBLIC_MODE=true
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=
JOB_SEARCH_TITLE=Software Engineer
JOB_SEARCH_LOCATION=Remote
JOB_SEARCH_EXPERIENCE_LEVEL=mid
JOB_SEARCH_DATE_POSTED=past_week
SCRAPER_MAX_PAGES=5
SCRAPER_DELAY_MIN=3
SCRAPER_DELAY_MAX=15
SCRAPER_HEADLESS=true
# Guest/public LinkedIn search without login
SCRAPER_PUBLIC_MODE=false

# Application safety — defaults ON (blocks auto-submit until /approve)
REVIEW_BEFORE_SUBMIT=true

# Claude (cover letters + application help)
CLAUDE_API_KEY=
# Optional override (default: claude-sonnet-4-20250514)
CLAUDE_MODEL=

# Telegram bot (outbound alerts + inbound /answer /approve commands)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Hour (UTC) to send daily summary via bot polling loop
DAILY_SUMMARY_HOUR_UTC=7

# Frontend → backend
NEXT_PUBLIC_API_URL=http://localhost:8000
