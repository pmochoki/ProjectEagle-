{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jobdragon.local/schemas/profile.json",
  "title": "JobDragon Applicant Profile",
  "description": "Structured profile data for resume tailoring, cover letters, and ATS answers. Never fabricate fields beyond this schema.",
  "type": "object",
  "required": ["contact", "summary", "skills", "experience", "projects", "education"],
  "additionalProperties": false,
  "properties": {
    "contact": {
      "type": "object",
      "required": ["full_name", "email"],
      "additionalProperties": false,
      "properties": {
        "full_name": { "type": "string", "minLength": 1 },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "location": { "type": "string" },
        "linkedin_url": { "type": "string", "format": "uri" },
        "github_url": { "type": "string", "format": "uri" },
        "portfolio_url": { "type": "string", "format": "uri" }
      }
    },
    "summary": {
      "type": "string",
      "description": "Professional summary paragraph(s)."
    },
    "skills": {
      "type": "object",
      "description": "Skills tagged by category.",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string", "minLength": 1 }
      },
      "properties": {
        "control_systems": { "type": "array", "items": { "type": "string" } },
        "programming": { "type": "array", "items": { "type": "string" } },
        "hardware": { "type": "array", "items": { "type": "string" } },
        "cad": { "type": "array", "items": { "type": "string" } },
        "languages": { "type": "array", "items": { "type": "string" } }
      }
    },
    "experience": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["role", "company", "start_date", "bullets"],
        "additionalProperties": false,
        "properties": {
          "role": { "type": "string" },
          "company": { "type": "string" },
          "location": { "type": "string" },
          "start_date": {
            "type": "string",
            "description": "ISO date (YYYY-MM) or free-text month/year."
          },
          "end_date": {
            "type": ["string", "null"],
            "description": "ISO date, free-text, or null if current."
          },
          "is_current": { "type": "boolean", "default": false },
          "bullets": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "minItems": 1
          }
        }
      }
    },
    "projects": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "description", "why_it_matters"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "why_it_matters": {
            "type": "string",
            "description": "Framing for cover letters and tailored resume emphasis."
          },
          "github_url": { "type": "string", "format": "uri" },
          "technologies": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "education": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["institution", "degree"],
        "additionalProperties": false,
        "properties": {
          "institution": { "type": "string" },
          "degree": { "type": "string" },
          "field": { "type": "string" },
          "start_date": { "type": "string" },
          "end_date": { "type": "string" },
          "honors": { "type": "string" }
        }
      }
    },
    "qa_memory": {
      "type": "array",
      "description": "Optional seed entries; runtime Q&A is stored in Supabase qa_memory table.",
      "items": {
        "type": "object",
        "required": ["question_text", "answer_text"],
        "additionalProperties": false,
        "properties": {
          "question_text": { "type": "string" },
          "answer_text": { "type": "string" }
        }
      },
      "default": []
    }
  }
}
